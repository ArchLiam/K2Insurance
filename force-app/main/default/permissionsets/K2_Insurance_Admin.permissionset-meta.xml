<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Full admin access to K2 Insurance domain objects: Insurance, Renewal (Opportunity), Quote, Commission Statement/Line, and Account (Insurance Provider).</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>K2 Insurance Admin</label>
    <license>Salesforce</license>

    <!-- Apex Class Access -->
    <classAccesses>
        <apexClass>QuotePdfController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>QuoteCreateController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ContentNoteCreator</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <!-- Visualforce Page Access -->
    <pageAccesses>
        <apexPage>K2QuotePdf</apexPage>
        <enabled>true</enabled>
    </pageAccesses>

    <!-- Object Permissions -->
    <objectPermissions>
