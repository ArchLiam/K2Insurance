<apex:page controller="QuotePdfController"
           renderAs="pdf"
           applyHtmlTag="false"
           applyBodyTag="false"
           showHeader="false"
           sidebar="false"
           standardStylesheets="false"
           cache="false">
<html>
<head>
<style type="text/css">
    @page { size: letter; margin: 0.5in 0.55in; }
    body {
        font-family: 'Helvetica', 'Arial', sans-serif;
        font-size: 11px;
        color: #1a1a1a;
        margin: 0;
        padding: 0;
    }
    .header {
        border-bottom: 3px solid #032d42;
        padding-bottom: 14px;
        margin-bottom: 22px;
    }
    .header-table { width: 100%; }
    .header-table td { vertical-align: middle; }
    .logo-cell { width: 40%; }
    .logo-cell img { display: block; height: 56px; width: auto; }
    .header-right { text-align: right; color: #032d42; }
    .header-right h1 {
        font-size: 26px;
        font-weight: 300;
        letter-spacing: 4px;
        margin: 0 0 4px 0;
        color: #032d42;
    }
    .header-right .meta { font-size: 10px; color: #666; }
    .header-right .meta-line { margin-top: 2px; }

    .section-label {
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #5fcfc3;
        border-bottom: 1px solid #e0e0dc;
        padding-bottom: 6px;
        margin-bottom: 10px;
        margin-top: 18px;
    }

    .parties { width: 100%; margin-top: 4px; }
    .parties td { width: 50%; padding: 0 12px 0 0; vertical-align: top; }
    .party-block .name { font-size: 14px; font-weight: 600; color: #032d42; margin: 0 0 4px 0; }
    .party-block .line { font-size: 11px; color: #1a1a1a; margin: 2px 0; }
    .party-block .label {
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #888;
        margin-bottom: 4px;
    }

    .detail-table { width: 100%; border-collapse: collapse; margin-top: 8px; }
    .detail-table td {
        padding: 8px 12px;
        border-bottom: 1px solid #eeeeea;
        font-size: 11px;
        vertical-align: top;
    }
    .detail-table td.label { width: 38%; color: #777; font-weight: 500; }
    .detail-table td.value { color: #1a1a1a; font-weight: 600; }

    .totals-table { width: 60%; margin-left: 40%; margin-top: 14px; border-collapse: collapse; }
    .totals-table td { padding: 6px 0; font-size: 11px; }
    .totals-table td.label { text-align: right; color: #666; padding-right: 16px; }
    .totals-table td.value { text-align: right; color: #1a1a1a; font-weight: 600; width: 110px; }
    .totals-table tr.grand td {
        border-top: 2px solid #032d42;
        padding-top: 10px;
        font-size: 13px;
        font-weight: 700;
        color: #032d42;
    }

    .acceptance {
        margin-top: 26px;
        padding: 16px 18px;
        background-color: #f8f8f6;
        border: 1px solid #e8e8e4;
    }
    .acceptance h3 {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #032d42;
        margin: 0 0 14px 0;
    }
    .acceptance-row { width: 100%; margin: 8px 0; }
    .acceptance-row td.field-label {
        width: 70px;
        font-size: 10px;
        color: #666;
        padding: 8px 4px 0 0;
        vertical-align: top;
    }
    .acceptance-row td.field-line { border-bottom: 1px solid #999; height: 22px; }

    .footer {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        text-align: center;
        font-size: 9px;
        color: #999;
        border-top: 1px solid #e8e8e4;
        padding-top: 8px;
    }

    .description {
        font-size: 10px;
        color: #555;
        line-height: 1.5;
        margin-top: 6px;
        white-space: pre-wrap;
    }
</style>
</head>
<body>

<div class="header">
    <table class="header-table">
        <tr>
            <td class="logo-cell">
                <img src="{!URLFOR($Resource.K2Logo)}" alt="K2 Insurance"/>
            </td>
            <td class="header-right">
                <h1>QUOTE</h1>
                <div class="meta">Quote # <strong>{!q.QuoteNumber}</strong></div>
                <div class="meta meta-line">
                    <apex:outputText value="{0,date,MMMM d, yyyy}">
                        <apex:param value="{!q.CreatedDate}"/>
                    </apex:outputText>
                </div>
                <apex:outputPanel rendered="{!NOT(ISNULL(q.ExpirationDate))}">
                    <div class="meta meta-line">
                        Valid through:
                        <apex:outputText value="{0,date,MMMM d, yyyy}">
                            <apex:param value="{!q.ExpirationDate}"/>
                        </apex:outputText>
                    </div>
                </apex:outputPanel>
            </td>
        </tr>
    </table>
</div>

<table class="parties">
    <tr>
        <td>
            <div class="party-block">
                <div class="label">Prepared For</div>
                <div class="name">{!IF(NOT(ISBLANK(q.QuoteToName)), q.QuoteToName, IF(NOT(ISBLANK(q.BillingName)), q.BillingName, q.Name))}</div>
                <apex:outputPanel rendered="{!NOT(ISBLANK(q.Contact.Name))}">
                    <div class="line">{!q.Contact.Name}</div>
                </apex:outputPanel>
                <apex:outputPanel rendered="{!NOT(ISBLANK(q.Email))}">
                    <div class="line">{!q.Email}</div>
                </apex:outputPanel>
                <apex:outputPanel rendered="{!NOT(ISBLANK(q.Phone))}">
                    <div class="line">{!q.Phone}</div>
                </apex:outputPanel>
            </div>
        </td>
        <td>
            <div class="party-block">
                <div class="label">Insurance Provider</div>
                <div class="name">{!IF(NOT(ISNULL(q.Insurance_Provider__r)), q.Insurance_Provider__r.Name, '—')}</div>
                <div class="line"><strong>Prepared by:</strong> {!q.Owner.Name}</div>
                <apex:outputPanel rendered="{!NOT(ISBLANK(q.Owner.Email))}">
                    <div class="line">{!q.Owner.Email}</div>
                </apex:outputPanel>
            </div>
        </td>
    </tr>
</table>

<div class="section-label">Quote Details</div>
<table class="detail-table">
    <apex:outputPanel rendered="{!NOT(ISBLANK(q.Plan_Name__c))}" layout="none">
        <tr>
            <td class="label">Plan Name</td>
            <td class="value">{!q.Plan_Name__c}</td>
        </tr>
    </apex:outputPanel>
    <apex:outputPanel rendered="{!NOT(ISNULL(q.Proposed_Start_Date__c))}" layout="none">
        <tr>
            <td class="label">Proposed Start Date</td>
            <td class="value">
                <apex:outputText value="{0,date,MMMM d, yyyy}">
                    <apex:param value="{!q.Proposed_Start_Date__c}"/>
                </apex:outputText>
            </td>
        </tr>
    </apex:outputPanel>
    <apex:outputPanel rendered="{!NOT(ISNULL(q.Proposed_Term_months__c))}" layout="none">
        <tr>
            <td class="label">Term</td>
            <td class="value">{!q.Proposed_Term_months__c} months</td>
        </tr>
    </apex:outputPanel>
    <apex:outputPanel rendered="{!NOT(ISBLANK(q.Status))}" layout="none">
        <tr>
            <td class="label">Status</td>
            <td class="value">{!q.Status}</td>
        </tr>
    </apex:outputPanel>
</table>

<table class="totals-table">
    <apex:outputPanel rendered="{!NOT(ISNULL(q.Proposed_Premium__c))}" layout="none">
        <tr>
            <td class="label">Proposed Premium</td>
            <td class="value">
                <apex:outputText value="{0, number, currency}">
                    <apex:param value="{!q.Proposed_Premium__c}"/>
                </apex:outputText>
            </td>
        </tr>
    </apex:outputPanel>
    <apex:outputPanel rendered="{!NOT(ISNULL(q.Discount))}" layout="none">
        <tr>
            <td class="label">Discount</td>
            <td class="value">{!q.Discount}%</td>
        </tr>
    </apex:outputPanel>
    <tr class="grand">
        <td class="label">Grand Total</td>
        <td class="value">
            <apex:outputText value="{0, number, currency}">
                <apex:param value="{!IF(NOT(ISNULL(q.GrandTotal)), q.GrandTotal, IF(NOT(ISNULL(q.Proposed_Premium__c)), q.Proposed_Premium__c, 0))}"/>
            </apex:outputText>
        </td>
    </tr>
</table>

<apex:outputPanel rendered="{!NOT(ISBLANK(q.Description))}" layout="none">
    <div class="section-label">Notes</div>
    <div class="description">{!q.Description}</div>
</apex:outputPanel>

<div class="acceptance">
    <h3>Quote Acceptance</h3>
    <table class="acceptance-row">
        <tr><td class="field-label">Signature</td><td class="field-line"></td></tr>
    </table>
    <table class="acceptance-row">
        <tr><td class="field-label">Name</td><td class="field-line"></td></tr>
    </table>
    <table class="acceptance-row">
        <tr><td class="field-label">Title</td><td class="field-line"></td></tr>
    </table>
    <table class="acceptance-row">
        <tr><td class="field-label">Date</td><td class="field-line"></td></tr>
    </table>
</div>

<div class="footer">
    K2 Insurance &middot; {!q.QuoteNumber} &middot; Generated
    <apex:outputText value="{0,date,MMMM d, yyyy}">
        <apex:param value="{!NOW()}"/>
    </apex:outputText>
</div>

</body>
</html>
</apex:page>
