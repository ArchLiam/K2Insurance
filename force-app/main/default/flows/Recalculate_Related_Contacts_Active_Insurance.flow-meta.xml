            <value>
                <elementReference>varInsuranceId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>varSourceFlow</name>
            <value>
                <stringValue>Recalculate_Related_Contacts_Active_Insurance</stringValue>
            </value>
        </inputAssignments>
    </subflows>
    <variables>
