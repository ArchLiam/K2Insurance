        <faultConnector>
            <targetReference>Log_the_Error</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>Business_Personal_Property__c</field>
            <value>
                <elementReference>Get_Synced_Quote.Coverage_Amount__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Company__c</field>
            <value>
                <elementReference>Get_Original_Insurance.Company__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Deductible__c</field>
            <value>
                <elementReference>Get_Synced_Quote.Deductible__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Insurance_Provider__c</field>
            <value>
                <elementReference>Get_Synced_Quote.Insurance_Provider__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Insurance_Start_Date__c</field>
            <value>
                <elementReference>Get_Synced_Quote.Proposed_Start_Date__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Insurance_Term_months__c</field>
            <value>
                <elementReference>Get_Synced_Quote.Proposed_Term_months__c</elementReference>
