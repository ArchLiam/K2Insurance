            </value>
        </inputAssignments>
        <inputAssignments>
            <name>varRecordId</name>
            <value>
                <elementReference>varRenewalOpportunity.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>varSeverity</name>
            <value>
                <stringValue>High</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>varSourceFlow</name>
            <value>
                <stringValue>Renewal_Closed_Won_Create_New_Insurance</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>varSourceStep</name>
            <value>
                <stringValue>Create_New_Insurance / Update_Renewal_with_New_Insurance</stringValue>
