<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>67.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>2026-07-21: Subscriber for the Exception__e platform event — persists one Error_Log__c row per event (message/stack truncated to 255 for the TextArea fields). Runs in its own transaction after the event is published, so the log survives even when the publishing transaction rolled back. New durable-logging sink behind the shared Log_Error subflow (Compliance flow-compliance.md §3.4/§3.5).</description>
    <environments>Default</environments>
    <formulas>
        <name>fxErrorMessage255</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Record.Error_Message__c}, 255)</expression>
    </formulas>
    <formulas>
        <name>fxStackTrace255</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Record.Stack_Trace__c}, 255)</expression>
    </formulas>
    <interviewLabel>Exception Event Logger {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Exception Event Logger</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>Create_Error_Log</name>
        <label>Create Error Log</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>Apex_Class__c</field>
            <value>
                <elementReference>$Record.Source_Flow__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Apex_Method__c</field>
            <value>
                <elementReference>$Record.Source_Step__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Context_Info__c</field>
            <value>
                <elementReference>$Record.Context__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Error_Message__c</field>
            <value>
                <elementReference>fxErrorMessage255</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Record_Involved__c</field>
            <value>
                <elementReference>$Record.Record_Id__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Severity__c</field>
            <value>
                <elementReference>$Record.Severity__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Stack_Trace__c</field>
            <value>
                <elementReference>fxStackTrace255</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>User__c</field>
            <value>
                <elementReference>$Record.User_Id__c</elementReference>
            </value>
        </inputAssignments>
        <object>Error_Log__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Create_Error_Log</targetReference>
        </connector>
        <flowRunAsUser>TriggeringUser</flowRunAsUser>
        <object>Exception__e</object>
        <triggerType>PlatformEvent</triggerType>
    </start>
    <status>Active</status>
</Flow>
