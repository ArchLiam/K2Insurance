            <targetReference>Update_Insurance_Commission_Rate</targetReference>
        </connector>
    </assignments>
    <description>When an Insurance policy's Subagent is set or changed, copy that agent's Commission Rate onto the policy's Commission Rate.</description>
    <decisions>
