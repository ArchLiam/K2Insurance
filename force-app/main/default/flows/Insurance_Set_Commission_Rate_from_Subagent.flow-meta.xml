    <assignments>
        <name>Set_Commission_Rate</name>
        <label>Set Commission Rate</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>varNewInsuranceRecord.Commission_Rate__c</assignToReference>
            <operator>Assign</operator>
