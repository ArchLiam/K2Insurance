        <label>Subagent Changed?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No Change</defaultConnectorLabel>
        <rules>
            <name>Changed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varNewInsuranceRecord.Subagent__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varNewInsuranceRecord.Subagent__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>varOldInsuranceRecord.Subagent__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Subagent</targetReference>
            </connector>
            <label>Changed</label>
        </rules>
    </decisions>
